---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineEntry from '../components/TimelineEntry.astro';
---

<BaseLayout
  title="Education — Andrés Matesanz"
  description="Academic background of Andrés Matesanz: Master's in AI & Software Engineering, Master's in VR/AR, and BSc in Optics."
>
  <h1 class="text-3xl font-bold text-gray-900 mb-2">🧑‍🎓 Education</h1>
  <p class="text-gray-500 mb-10">
    My main academic achievements. I have more — if you want to know about my full educational experience, ask me! 🙂
  </p>

  <!-- Jump links -->
  <div class="flex flex-wrap gap-2 mb-10">
    <a href="#ai-master" class="btn-outline text-xs px-3 py-1.5">🎓 Master in AI & SE</a>
    <a href="#vr-master" class="btn-outline text-xs px-3 py-1.5">🎓 Master in VR/AR</a>
    <a href="#bsc-optics" class="btn-outline text-xs px-3 py-1.5">🎓 BSc in Optics</a>
  </div>

  <div class="relative">

    <!-- MSc AI & Software Engineering -->
    <div id="ai-master">
      <TimelineEntry
        title="Master's in Artificial Intelligence and Software Engineering"
        subtitle="University of Malaga — Mention in Research"
        period="Sept 2019 – June 2020"
      >
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          Master focused on the different areas of <strong>Artificial Intelligence</strong> and <strong>Software Development</strong>:
          Reinforcement Learning, Generative Models, Big Data, Evolutive Algorithms.
        </p>
        <div class="space-y-2">
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="text-yellow-500 font-bold mt-0.5">🌟</span>
            <div>
              <strong>Master Thesis (Graduated with Honors)</strong>:{' '}
              <a href="https://1drv.ms/b/s!AgDuqWQZkjwxj79zyt5colGiRdNT1g?e=1cslcH" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">
                3D MRI Super-Resolution using Generative Adversarial Networks
              </a>{' '}—
              development of a super-resolution model for 3D MRI using GANs, increasing image quality by 4×.{' '}
              <a href="https://github.com/Matesanz/WGAN-GP_MRI_Super_Resolution" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Code]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Multi-Agent Optimization</strong>: Last mile delivery optimization using multi-agent theory.{' '}
              <a href="https://github.com/Matesanz/Last_Mile_MultiAgents" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Code]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Evolutive Algorithms</strong>: Optimization algorithms to reconstruct unordered image rows.{' '}
              <a href="https://github.com/Matesanz/Image_Reconstruction_Evolutive_Algorithms" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Code]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Big Data</strong>: Spark analysis of NYC taxi prices during New Year's Eve.{' '}
              <a href="https://github.com/Matesanz/NYCTaxi_Spark" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Code]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Generative Models</strong>: Variational Auto Encoders for generating new MNIST instances.
            </div>
          </div>
        </div>
      </TimelineEntry>
    </div>

    <!-- MSc VR/AR -->
    <div id="vr-master">
      <TimelineEntry
        title="Master's in VR, AR and Videogame Development"
        subtitle="VR EVO School"
        period="Sept 2017 – June 2018"
      >
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          Multiple areas related to <strong>Virtual Reality</strong>, <strong>Augmented Reality</strong>, and
          <strong>video-game development</strong> (game theory, procedural generation, archviz).
          Using <strong>Unreal Engine 4</strong>, Blender, Maya and 3D MAX.
        </p>
        <div class="space-y-2">
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Artsenal VR Experience</strong>: VR experience with movement tracking at the XII edition of
              <em>La Noche en Blanco</em> at Artsenal Museum, Málaga.{' '}
              <a href="https://youtu.be/RBG4qE5czRk" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Video]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Procedural Museum</strong>: Auto-generated VR museum featuring famous art pieces.{' '}
              <a href="https://vimeo.com/254240325" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Video]</a>
              {' '}+ mobile version <em>The Gallery</em>.{' '}
              <a href="https://vimeo.com/272375915" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Video]</a>
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>The Universe</strong>: Mobile app to explore the Solar System.{' '}
              <a href="https://vimeo.com/273707600" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">[Video]</a>
            </div>
          </div>
        </div>
      </TimelineEntry>
    </div>

    <!-- BSc Optics -->
    <div id="bsc-optics">
      <TimelineEntry
        title="Bachelor's Degree in Optics"
        subtitle="University of Valladolid & Bicocca University (Erasmus)"
        period="Sept 2011 – June 2015"
      >
        <p class="text-sm text-gray-700 leading-relaxed mb-4">
          Degree focused on <strong>physics</strong>, <strong>mathematics</strong>, <strong>neurology</strong> and
          <strong>biology</strong> related to the fields of vision and optics. International <strong>Erasmus</strong> exchange
          at <strong>Bicocca University</strong> (2013–2014).
        </p>
        <div class="space-y-2">
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>Bachelor Thesis</strong>:{' '}
              <a href="https://uvadoc.uva.es/handle/10324/13397?locale-attribute=it" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">
                Changes in the Visual Function after the Critical Period
              </a>{' '}
              — study on human vision development at a cortex level.
            </div>
          </div>
          <div class="flex items-start gap-2 text-sm text-gray-700">
            <span class="mt-0.5">•</span>
            <div>
              <strong>2nd Place at Cooper FORCE Competition 2015</strong>: Research on new techniques to adapt multifocal contact lenses.
            </div>
          </div>
        </div>
      </TimelineEntry>
    </div>

  </div>
</BaseLayout>
