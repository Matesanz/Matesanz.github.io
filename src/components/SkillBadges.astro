<section class="py-8">
  <h2 class="section-title">🔧 Technologies I work with</h2>
  <div class="space-y-6">
    {categories.map(cat => (
      <div>
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">{cat.name}</h3>
        <div class="flex flex-wrap gap-2">
          {cat.badges.map(badge => (
            <img src={badge.url} alt={badge.label} loading="lazy" class="h-7" />
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
